# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
=0.4.0

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
.env/

# ── Environment variables (secrets — never commit) ────────────────────────────
.env
.env.*
!.env.example

# ── Training images (large — only needed to rebuild FAISS index, not at runtime)
data/images/
data/audio/

# ── Trained model weights (large binary files — regenerated by train.py) ──────
models/intent_classifier/
models/*.index
models/*.json
*.pt
*.pth
*.bin
*.ckpt

# ── FAISS index (regenerated by src/build_image_index.py) ────────────────────
models/faiss_kb.index
models/faiss_id_map.json

# ── Logs & server output files ────────────────────────────────────────────────
*.log
backend_out*.log
build_index_log.txt
/tmp/

# ── Scratch / one-off test scripts (not part of the test suite) ───────────────
test_clip.py
test_scenarios.py
test_scenarios_results.json

# ── Jupyter notebook checkpoints ─────────────────────────────────────────────
.ipynb_checkpoints/

# ── Coverage & test cache ─────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.xml

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
