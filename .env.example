# Backend environment variables
# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit it.

# ── Groq LLM ─────────────────────────────────────────────────────────────────
GROK_API_KEY=your_groq_api_key_here
# Optional: override the model (default: llama-3.1-8b-instant)
# GROQ_MODEL=llama-3.1-8b-instant
# Optional: disable LLM and use template responses (default: true)
# USE_LLM=true

# ── Data & model paths (defaults work for local dev) ─────────────────────────
KB_PATH=data/campus_kb.json
CSV_PATH=data/faq_dataset.csv
MODEL_SAVE_DIR=models/intent_classifier
FAISS_INDEX_PATH=models/faiss_kb.index
FAISS_ID_MAP_PATH=models/faiss_id_map.json
LOG_LEVEL=INFO
